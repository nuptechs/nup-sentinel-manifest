{
  "name": "nup-manifest-vscode",
  "displayName": "Manifest - Code Permission Catalog",
  "description": "Analyze frontend-to-backend interactions, generate permission catalogs, and detect security gaps directly from VS Code.",
  "version": "0.1.0",
  "publisher": "nuptechs",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nup-manifest.analyzeFile",
        "title": "Manifest: Analyze Current File"
      },
      {
        "command": "nup-manifest.analyzeWorkspace",
        "title": "Manifest: Analyze Workspace (Local)"
      },
      {
        "command": "nup-manifest.analyzeWorkspaceFull",
        "title": "Manifest: Analyze Workspace (Full Remote)"
      },
      {
        "command": "nup-manifest.showCatalog",
        "title": "Manifest: Show Catalog"
      },
      {
        "command": "nup-manifest.connectServer",
        "title": "Manifest: Connect to Server"
      },
      {
        "command": "nup-manifest.clearResults",
        "title": "Manifest: Clear Results"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nup-manifest-explorer",
          "title": "Manifest",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "nup-manifest-explorer": [
        {
          "id": "nup-manifest-catalog-tree",
          "name": "Catalog"
        }
      ]
    },
    "configuration": {
      "title": "Manifest",
      "properties": {
        "nup-manifest.serverUrl": {
          "type": "string",
          "default": "",
          "description": "URL of the Manifest analysis server"
        },
        "nup-manifest.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authenticating with the Manifest server"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
