{
  "client_name": "Manifest",
  "application_type": "web",
  "system_id": "manifest",

  "response_types": ["code"],
  "grant_types": ["authorization_code", "refresh_token"],
  "scope": "openid profile email offline_access",

  "token_endpoint_auth_method": "client_secret_post",
  "code_challenge_methods_supported": ["S256"],
  "id_token_signed_response_alg": "RS256",

  "redirect_uris": [
    "https://manifest.nuptechs.com/auth/callback",
    "http://localhost:5000/auth/callback"
  ],
  "post_logout_redirect_uris": [
    "https://manifest.nuptechs.com",
    "http://localhost:5000"
  ],

  "_comment": "Register this client in NuPIdentity admin panel. The system_id 'manifest' will prefix all permissions assigned to this application (e.g. manifest:projects.read)."
}
